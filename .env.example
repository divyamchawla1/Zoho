# Copy to .env.local and fill in. Never commit real values.
# Anything prefixed NEXT_PUBLIC_ ships in the browser bundle and is PUBLIC.

# Canonical URLs, sitemap, OG images. TBD — see CONTENT_GAPS_AND_TBDS.md
NEXT_PUBLIC_SITE_URL=https://example.com

# none | resend | formspree | zoho-forms
# With "none" the form shows the mailto fallback and states that it is not connected.
# It must never simulate a successful send.
CONTACT_PROVIDER=none

# Recipient for enquiries. TBD.
CONTACT_TO_EMAIL=

# Only the one matching CONTACT_PROVIDER is needed. Server-side only — never NEXT_PUBLIC_.
RESEND_API_KEY=
FORMSPREE_ENDPOINT=
ZOHO_FORM_ENDPOINT=

# Optional. TBD — decide whether to have analytics at all.
NEXT_PUBLIC_ANALYTICS_ID=
